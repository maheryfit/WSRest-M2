{
	"info": {
		"name": "Food Delivery API - MBDS (Final)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "0. AUTH (Scripts Auto)",
			"item": [
				{
					"name": "Login (Récupère le Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData;",
									"try {",
									"    jsonData = pm.response.json();",
									"} catch (e) {",
									"    console.log(\"Response is not JSON:\", pm.response.text());",
									"}",
									"",
									"if (jsonData && jsonData.token) {",
									"    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
									"    console.log(\"Token ADMIN sauvegardé !\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"client1@gmail.com\",\n    \"motDePasse\": \"password\"\n}",
							"options": { "json": { "language": "json" } }
						},
						"url": "{{base_url}}/api/utilisateurs/login"
					}
				}
			]
		},
		{
			"name": "1. CLIENT (RAKOTO Jean)",
			"item": [
				{ "name": "Mon Profil", "request": { "method": "GET", "url": "{{base_url}}/api/clients/me" }},
				{ "name": "Mes Adresses", "request": { "method": "GET", "url": "{{base_url}}/api/clients/me/adresses" }},
				{ "name": "Passer Commande (Burger Shop)", "request": { 
					"method": "POST", 
					"url": "{{base_url}}/api/commandes",
					"body": { "mode": "raw", "raw": "{\n    \"restaurantId\": 1,\n    \"modePaiement\": \"CARTE\",\n    \"items\": [{\"platId\": 1, \"quantite\": 2}]\n}", "options": { "json": { "language": "json" } }}
				}}
			]
		},
		{
			"name": "2. RESTAURANT (Burger Shop)",
			"item": [
				{ "name": "Mes Commandes", "request": { "method": "GET", "url": "{{base_url}}/api/restaurants/me/commandes" }},
				{ "name": "Accepter Commande 1", "request": { "method": "POST", "url": "{{base_url}}/api/restaurants/me/commandes/1/accepter" }}
			]
		},
		{
			"name": "3. LIVREUR (Paul)",
			"item": [
				{ "name": "Mes Livraisons", "request": { "method": "GET", "url": "{{base_url}}/api/livreurs/me/commandes" }},
				{ "name": "Update Statut DISPONIBLE", "request": { "method": "PATCH", "url": "{{base_url}}/api/livreurs/me/statut", "body": { "mode": "raw", "raw": "{\"statut\": \"DISPONIBLE\"}", "options": { "json": { "language": "json" } }} }}
			]
		},
		{
			"name": "4. ADMIN & STATS",
			"item": [
				{ "name": "Top Restaurants", "request": { "method": "GET", "url": "{{base_url}}/api/stats/restaurants/top?from=2026-01-01" }},
				{ "name": "Lister tous les Users", "request": { "method": "GET", "url": "{{base_url}}/api/users" }}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8080" },
		{ "key": "jwt_token", "value": "" }
	]
}