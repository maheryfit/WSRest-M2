      ]
    },
    {
      "name": "2 - GET /stats/clients/meilleurs",
      "description": "Liste des meilleurs clients : total dépensé, nombre de commandes livrées, panier moyen.\n\nRègle : seules les commandes avec statutCommande.libelle = 'LIVREE' sont comptabilisées.\nTrié par total dépensé décroissant.\n\nChamps retournés : clientId, nom, totalDepense, nombreCommandes, panierMoyen.",
      "item": [
        {
          "name": "Meilleurs Clients — liste complète",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/stats/clients/meilleurs",
              "host": ["{{base_url}}"],
              "path": ["api", "stats", "clients", "meilleurs"]
            }
          }
        }
      ]
    },
    {
      "name": "3 - GET /stats/commandes/par-jour",
      "description": "Nombre de commandes agrégées par jour (toutes commandes, sans filtre de statut).\nTrié par date ascendante.\n\nChamps retournés : date_creation, nombreCommandes.\n\nNote : le controller actuel n'expose pas de paramètres from/to pour cet endpoint.",
      "item": [
        {
          "name": "Commandes par Jour — toutes dates",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/stats/commandes/par-jour",
              "host": ["{{base_url}}"],
              "path": ["api", "stats", "commandes", "par-jour"]
            }
          }
        }
      ]
    },
