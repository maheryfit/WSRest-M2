      "key": "token_client2",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0 - Auth",
      "item": [
        {
          "name": "Login Client 1 (RAKOTO Jean - client1@gmail.com)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('token_client1', pm.response.text());",
                  "pm.collectionVariables.set('jwt_token', pm.response.text());",
                  "console.log('Token Client 1 sauvegardé !');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client1@gmail.com\",\n  \"motDePasse\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/utilisateurs/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
