          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token_client1}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": 1,\n  \"modePaiement\": \"MOBILE_MONEY\",\n  \"lignesCommandes\": [\n    { \"platId\": 1, \"quantite\": 1, \"prixUnitaire\": 15000 }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/commandes",
