            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token_client1}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": 1,\n  \"clientId\": 1,\n  \"note\": 5,\n  \"commentaire\": \"Excellent service ! Le Cheese Burger était juteux et bien garni. Livraison rapide depuis Analakely. Je recommande vivement, le meilleur burger d'Antananarivo !\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/restaurants/1/avis",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "restaurants",
                "1",
                "avis"
              ]
            }
